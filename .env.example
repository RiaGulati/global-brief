# Global Brief — Environment Variables
# Copy this file to .env and fill in your values

# Server port (default: 5000)
PORT=5000

# Node environment: development | production
NODE_ENV=development

# Database path — absolute or relative to project root
# Default: data.db (SQLite file auto-created on first run)
# Set to a mounted volume path in Docker/Render/Fly for persistence:
# DB_PATH=/data/global-brief.db
